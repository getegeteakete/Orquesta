# ==========================================
# Anthropic
# ==========================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# freee OAuth2 アプリ設定
# https://developer.freee.co.jp/ でアプリ登録後に取得
# ==========================================
FREEE_CLIENT_ID=your_freee_client_id
FREEE_CLIENT_SECRET=your_freee_client_secret
FREEE_REDIRECT_URI=http://localhost:3000/api/freee/auth/callback

# ==========================================
# フロントエンド（デモ用。本番はCookieで管理）
# ==========================================
NEXT_PUBLIC_FREEE_ACCESS_TOKEN=your_access_token_for_demo
NEXT_PUBLIC_FREEE_COMPANY_ID=your_company_id

# ==========================================
# セッション管理（本番必須）
# ==========================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/freee_ai_cfo
# REDIS_URL=redis://localhost:6379
# SESSION_SECRET=your_session_secret_32chars_min
